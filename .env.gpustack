# .env.gpustack — GPUStack configuration for OUTREMER
# DO NOT COMMIT THIS FILE (already in .gitignore)
# Copy from .env.gpustack.example for local development

# GPUStack endpoint
GPUSTACK_BASE_URL=https://tei.dh.unibe.ch/v1
GPUSTACK_API_KEY=

# Model names (must match exactly how registered in GPUStack)
EXTRACTION_MODEL=qwen3-30b-a3b-instruct
ORCHESTRATOR_MODEL=minimax-m2.7

# OCR engine: easyocr (local) | gpustack (MiniMax-M2.7) | mistral (legacy)
OCR_ENGINE=easyocr

# Request timeout in seconds
GPUSTACK_TIMEOUT=120
